{
  "patterns": [
    {
      "name": "Email Address",
      "regex": "\\b[a-z0-9._%+\\-]+@[a-z0-9.-]+\\.[a-z]{2,6}\\b"
    },
    {
      "name": "Credit Card Number",
      "regex": "\\b(?:4[0-9]{12}(?:[0-9]{3})?|5[1-5][0-9]{14}|3[0-9]{13}|3(?:0[0-5]|[0-9])[0-9]{11}|6(?:011|5[0-9]{2})[0-9]{12}|(?:2131|1800|35\\d{3})\\d{11})\\b"
    },
    {
      "name": "IP Address (IPv4)",
      "regex": "\\b(?:(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.){3}(?:25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\b"
    },
    {
      "name": "Date of Birth",
      "regex": "\\b(0[1-9]|1[0-2])[/\\-](0[1-9]|[12]\\d|3[01])[/\\-](\\d{4}|\\d{2})\\b"
    },
    {
      "name": "UK Phone Number",
      "regex": "\\b([0O]?[1lI][1lI])?[4A][4A][\\dOIlZEASB]{10,11}\\b"
    },
    {
      "name": "IPv6 Address",
      "regex": "\\b([0-9a-fA-F]{4}|0)(:([0-9a-fA-F]{4}|0)){7}\\b"
    }
  ]
}
